{
  "name": "@mcp-use/agent",
  "type": "module",
  "version": "2.0.0-alpha.0",
  "description": "LangChain MCP agents for TypeScript — build AI agents with MCP tools.",
  "author": "mcp-use, Inc.",
  "license": "MIT",
  "homepage": "https://github.com/mcp-use/mcp-use#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcp-use/mcp-use.git",
    "directory": "libraries/typescript/packages/agent"
  },
  "bugs": {
    "url": "https://github.com/mcp-use/mcp-use/issues"
  },
  "keywords": [
    "MCP",
    "mcp-use",
    "Model Context Protocol",
    "agent",
    "langchain",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "default": "./dist/browser.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsup && tsc --emitDeclarationOnly --declaration",
    "test": "vitest run"
  },
  "dependencies": {
    "mcp-use": "workspace:*"
  },
  "peerDependencies": {
    "@langchain/anthropic": "^1.3.0",
    "@langchain/core": "^1.1.0",
    "@langchain/openai": "^1.2.0",
    "langchain": "^1.2.10",
    "langfuse": "^3.38.6",
    "langfuse-langchain": "^3.38.6",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "langfuse": {
      "optional": true
    },
    "langfuse-langchain": {
      "optional": true
    }
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
