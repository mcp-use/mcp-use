{
  "name": "@mcp-use/client",
  "type": "module",
  "version": "1.0.0",
  "description": "Client SDK for the mcp-use TypeScript framework — connect to MCP servers from browsers or Node.js.",
  "author": "mcp-use, Inc.",
  "license": "MIT",
  "homepage": "https://github.com/mcp-use/mcp-use#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcp-use/mcp-use.git",
    "directory": "libraries/typescript/packages/client"
  },
  "bugs": {
    "url": "https://github.com/mcp-use/mcp-use/issues"
  },
  "keywords": [
    "MCP",
    "mcp-use",
    "Model Context Protocol",
    "client",
    "connectors",
    "auth",
    "browser",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    },

    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs"
    },
    "./auth/node": {
      "types": "./dist/auth/index-node.d.ts",
      "import": "./dist/auth/index-node.js",
      "require": "./dist/auth/index-node.cjs"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsup && tsc --emitDeclarationOnly --declaration",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mcp-use/core": "workspace:*",
    "jose": "6.1.3"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.26.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "zod": "4.3.5"
  }
}
