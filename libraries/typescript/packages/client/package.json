{
  "name": "@mcp-use/client",
  "type": "module",
  "version": "2.0.0-alpha.0",
  "description": "MCP client for connecting to Model Context Protocol servers — sessions, connectors, and OAuth. Part of the mcp-use v2 framework.",
  "author": "mcp-use, Inc.",
  "license": "MIT",
  "homepage": "https://github.com/mcp-use/mcp-use#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcp-use/mcp-use.git",
    "directory": "libraries/typescript/packages/client"
  },
  "bugs": {
    "url": "https://github.com/mcp-use/mcp-use/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "client",
    "oauth",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "rimraf dist && tsup && tsc --emitDeclarationOnly --declaration",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.0.1",
    "@modelcontextprotocol/sdk": "1.26.0",
    "posthog-js": "1.351.3",
    "posthog-node": "5.24.17"
  },
  "peerDependencies": {
    "@e2b/code-interpreter": "^2.2.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@e2b/code-interpreter": {
      "optional": true
    }
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
