{
  "name": "@mcp-use/server",
  "type": "module",
  "version": "1.0.0",
  "description": "Server SDK for the mcp-use TypeScript framework — build MCP servers with OAuth, tools, resources, widgets, and more.",
  "author": "mcp-use, Inc.",
  "license": "MIT",
  "homepage": "https://github.com/mcp-use/mcp-use#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcp-use/mcp-use.git",
    "directory": "libraries/typescript/packages/server"
  },
  "bugs": {
    "url": "https://github.com/mcp-use/mcp-use/issues"
  },
  "keywords": [
    "MCP",
    "mcp-use",
    "Model Context Protocol",
    "server",
    "oauth",
    "tools",
    "resources",
    "widgets",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsup && tsc --emitDeclarationOnly --declaration",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mcp-use/core": "workspace:*",
    "@mcp-use/client": "workspace:*",
    "@hono/node-server": "1.19.13",
    "@mcp-ui/server": "6.1.0",
    "@mcp-use/cli": "workspace:*",
    "@modelcontextprotocol/ext-apps": "1.0.1",
    "express": "5.2.1",
    "hono": "4.12.23",
    "jose": "6.1.3",
    "posthog-node": "5.24.17"
  },
  "optionalDependencies": {
    "cli-highlight": "2.1.11",
    "redis": "5.10.0"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.26.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "@types/express": "^5.0.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "zod": "4.3.5"
  }
}
