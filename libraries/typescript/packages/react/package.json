{
  "name": "@mcp-use/react",
  "type": "module",
  "version": "1.0.0",
  "description": "React integration for the mcp-use TypeScript framework — useMcp and useWidget hooks.",
  "author": "mcp-use, Inc.",
  "license": "MIT",
  "homepage": "https://github.com/mcp-use/mcp-use#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcp-use/mcp-use.git",
    "directory": "libraries/typescript/packages/react"
  },
  "bugs": {
    "url": "https://github.com/mcp-use/mcp-use/issues"
  },
  "keywords": [
    "MCP",
    "mcp-use",
    "Model Context Protocol",
    "react",
    "hooks",
    "widgets"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsup && tsc --emitDeclarationOnly --declaration",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mcp-use/core": "workspace:*",
    "@mcp-use/client": "workspace:*"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.26.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-router": "^7.12.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "react-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "react": "^19.2.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "zod": "4.3.5"
  }
}
