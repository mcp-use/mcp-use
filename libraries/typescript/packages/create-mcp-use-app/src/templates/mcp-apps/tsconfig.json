{
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "strict": true,
    "outDir": "./.mcp-use/build/server",
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": "./.mcp-use/cache/tsconfig.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "index.tsx",
    "components/**/*",
    "src/**/*",
    "resources/**/*",
    "server.ts",
    ".mcp-use/generated/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist", ".mcp-use/build"]
}
