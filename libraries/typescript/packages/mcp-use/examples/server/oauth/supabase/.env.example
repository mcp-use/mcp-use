# From https://supabase.com/dashboard/project/{PROJECT_ID}/settings/api-keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=***
# From https://supabase.com/dashboard/project/{PROJECT_ID}/settings/jwt/legacy
MCP_USE_OAUTH_SUPABASE_JWT_SECRET=***
MCP_USE_OAUTH_SUPABASE_PROJECT_ID=***

# In the Supabase Dashboard, under Authentication → OAuth Server, set the
# consent screen URL to the page this example hosts:
#   http://localhost:3000/auth/consent
# Supabase redirects users there after /authorize; this example handles
# sign-in and consent, then hands back to Supabase to issue the auth code.
#
# Also enable anonymous sign-ins in the dashboard under Auth → Providers →
# Anonymous. The example uses anonymous sign-in for zero-setup demo auth.
