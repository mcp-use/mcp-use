# Keycloak server base URL (no trailing slash, no /realms path).
# Defaults to http://localhost:8080 if unset.
MCP_USE_OAUTH_KEYCLOAK_SERVER_URL=http://localhost:8080

# Keycloak realm name. Defaults to `demo` if unset — matches the
# pre-seeded realm in the companion keycloak-auth-server repo.
MCP_USE_OAUTH_KEYCLOAK_REALM=demo

# Optional. If set, the provider enforces that the access token's `aud`
# claim equals this value. Requires an Audience protocol mapper on the
# client scope in Keycloak — otherwise tokens will be rejected.
# MCP_USE_OAUTH_KEYCLOAK_AUDIENCE=http://localhost:3000
