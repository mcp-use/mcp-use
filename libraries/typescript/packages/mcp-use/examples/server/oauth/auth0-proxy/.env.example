# Auth0 tenant domain (without https://)
AUTH0_DOMAIN=your-tenant.us.auth0.com

# Regular Web App credentials from Auth0 dashboard
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# API identifier — required to receive JWT access tokens (vs. opaque tokens)
AUTH0_AUDIENCE=https://your-api-identifier/

# Optional: server port (default 3000)
PORT=3000

# Optional: base URL for OAuth redirects (default http://localhost:{PORT})
BASE_URL=http://localhost:3000
