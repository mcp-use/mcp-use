# From https://supabase.com/dashboard/project/{PROJECT_ID}/settings/general
MCP_USE_OAUTH_SUPABASE_PROJECT_ID=your-project-id

# Publishable key (sb_publishable_...). Find it under Project Settings → API Keys.
MCP_USE_OAUTH_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Because this example mounts everything under basePath "/api", configure the
# consent screen URL in the Supabase Dashboard (Authentication → OAuth Server)
# to:
#   http://localhost:3000/api/auth/consent
#
# Also enable anonymous sign-ins under Auth → Providers → Anonymous.
