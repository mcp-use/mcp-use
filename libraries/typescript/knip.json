{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreIssues": {
    "packages/mcp-use/src/server/views/inline-widget-entry-gen.ts": ["exports", "types"]
  },
  "rules": {
    "optionalPeerDependencies": "off",
    "duplicates": "off"
  },
  "ignoreWorkspaces": [
    "packages/mcp-use/examples/**",
    "packages/create-mcp-use-app/src/templates/**",
    "test_app"
  ],
  "workspaces": {
    ".": {
      "project": ["*.{js,ts}"]
    },
    "packages/mcp-use": {
      "entry": [
        "scripts/**/*.{js,mjs,ts}",
        "tests/helpers/**/*.ts",
        "tests/servers/**/*.ts",
        "tests/docs/**/*.ts",
        "tests/types/**/*.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}"],
      "ignore": [
        "src/server/views/inline-widget-bundler.ts",
        "src/server/views/inline-widget-esbuild-plugin.ts",
        "src/server/views/inline-widget-transform.ts"
      ],
      "ignoreBinaries": ["lsof", "sleep", "dev"]
    },
    "packages/cli": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/inspector": {
      "entry": [
        "src/server/*.ts",
        "start-auth-servers.ts",
        "tests/e2e/**/*.{ts,tsx,mjs}"
      ],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "@scarf/scarf",
        "tailwindcss",
        "tw-animate-css"
      ]
    },
    "packages/create-mcp-use-app": {
      "entry": ["scripts/**/*.{js,mjs,ts}"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
